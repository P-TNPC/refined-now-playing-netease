{
	"compilerOptions": {
		"target": "ESNext",
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable",
			"WebWorker"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": [],
		"jsx": "react",
		"jsxFactory": "h",
		"jsxFragmentFactory": "f",
		"resolveJsonModule": true,
		"allowJs": true,
		"noEmit": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": [
		"./src/**/*.ts",
		"./src/**/*.tsx",
		"./src/**/*.jsx",
		"./*.css"
	],
	"exclude": [
		"./node_modules"
	]
}